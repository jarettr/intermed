'(--json --sarif)--html=[Write a self-contained HTML report (\`index.html\` style)]:FILE:_files' \
'--profile=[Write wall-clock phase profile JSON (\`intermed-doctor-profile-v1\`)]:FILE:_files' \
'--cache-dir=[Override jar cache root (default\: \$XDG_CACHE_HOME/intermed or ~/.cache/intermed)]:DIR:_files' \
'--cache-remote-dir=[Shared/remote cache tier directory (Tier 3). A scan payload written by one machine is reused by any other pointed at the same directory (e.g. a network mount or CI cache). The reference \`LocalDirRemoteTier\`; real S3/HTTP tiers implement the same \`RemoteCacheTier\` trait]:DIR:_files' \
'--cache-max-size=[Soft cap on jar cache size in MiB; oldest entries are pruned first (default\: 512). Useful on space-constrained or CI machines]:MIB:_default' \
'--cache-max-age-days=[Maximum age of jar cache entries in days before automatic pruning (default\: 180)]:DAYS:_default' \
'--changed-since=[Incremental scan\: only jars modified at or after this time (RFC3339 or unix seconds)]:TIME:_default' \
'--dump-facts=[Write the raw Phase-2 fact snapshot to a JSON file]:FILE:_files' \
'--explain=[Explain one finding id with its supporting facts]:FINDING_ID:_default' \
'--spark-report=[Explicit spark report JSON (\`intermed-spark-report-v1\`)]:FILE:_files' \
'--perf-tick-spike-ms=[Minimum tick spike duration in ms to report (default\: 50)]:MS:_default' \
'--perf-high-cpu-percent=[CPU percent at or above which hot methods/mods are treated as severe (default\: 50.0)]:PCT:_default' \
'--perf-hot-method-floor=[Minimum CPU percent for hot-method ↔ mixin correlation (default\: 5.0)]:PCT:_default' \
'--perf-tick-spike-warn-ms=[Tick spike severity bump threshold in ms (default\: 100)]:MS:_default' \
'--metadata-level=[Metadata analysis preset\: \`basic\`, \`enriched\`, or \`full\`]:LEVEL:(basic enriched full)' \
'--resource-level=[Resource/data-semantics (Layer M) AST depth\: \`basic\` (off), \`semantic\`, or \`full\`]:LEVEL:(basic semantic full)' \
'--security-min-note-signals=[Note-level security signals required before emitting a grouped finding (default\: 2)]:N:_default' \
'--sbom-well-identified-trust=[SBOM trust score (0..=100) for well-identified jars (default\: 60)]:SCORE:_default' \
'--log-parallel-line-threshold=[Log line count above which scanning uses parallel workers (default\: 4096)]:N:_default' \
'--security-corroborated-confidence=[Confidence for reflection-corroborated security facts (default\: 0.4)]:SCORE:_default' \
