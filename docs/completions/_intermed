'*--rule-pack=[Extra declarative rule packs\: file path or installed pack id (repeatable)]:PATH|ID:_default' \
'--rule-pack-dir=[Rule pack install directory (default\: XDG \`.../intermed/rule-packs\`)]:DIR:_files' \
'--rule-pack-trusted-keys=[Trusted publisher keys file for verifying signed rule pack overlays]:FILE:_files' \
'--rule-pack-registry=[Registry index path or URL for resolving \`--rule-pack\` ids]:FILE|URL:_default' \
'--config=[Config file (\`intermed-config-v1\` TOML). Overrides discovery; see docs/reference/configuration.md]:FILE:_files' \
'--mixin-risk[Enable Layer-F Mixin risk scanning during doctor]' \
'(--sarif --html)--json[Emit the full report as \`intermed-doctor-report-v1\` JSON]' \
'(--json --html)--sarif[Emit SARIF 2.1.0 (for IDE / CI code-scanning)]' \
'--no-color[Disable ANSI colour even on a TTY]' \
'--exit-zero[Exit 0 whenever the run completes, regardless of findings]' \
'--no-cache[Disable the on-disk jar scan cache (default\: cache enabled at XDG path)]' \
'--performance[Enable Layer-I Spark report import during doctor]' \
'(--mixin-handler-effects)--no-mixin-handler-effects[Skip per-handler bytecode intelligence facts and findings]' \
