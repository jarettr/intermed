{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intermed.dev/schemas/intermed-rule-pack-v2.schema.json",
  "title": "InterMed Declarative Rule Pack v2",
  "type": "object",
  "required": ["schema", "id", "rules"],
  "properties": {
    "schema": { "const": "intermed-rule-pack-v2" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "publisher": { "type": "string" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    },
    "signature": { "type": "object" }
  },
  "$defs": {
    "fact_source": {
      "type": "object",
      "required": ["kind", "alias"],
      "properties": {
        "kind": { "type": "string" },
        "alias": { "type": "string" },
        "select": { "type": "array", "items": { "type": "string" } }
      }
    },
    "finding": {
      "type": "object",
      "required": ["id", "severity", "category", "title", "explanation"],
      "properties": {
        "id": { "type": "string" },
        "severity": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "explanation": { "type": "string" },
        "fix": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rule": {
      "type": "object",
      "required": ["id", "kind", "finding"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "enum": [
            "group-distinct",
            "fact-finding",
            "join",
            "aggregate",
            "correlation"
          ]
        },
        "input_kinds": { "type": "array", "items": { "type": "string" } },
        "where_all": { "type": "object" },
        "where_not": { "type": "object" },
        "group_by": { "type": "string" },
        "group_by_fields": { "type": "array", "items": { "type": "string" } },
        "distinct": { "type": "string" },
        "min_count": { "type": "integer", "minimum": 1 },
        "left": { "$ref": "#/$defs/fact_source" },
        "right": { "$ref": "#/$defs/fact_source" },
        "on": { "type": "string" },
        "where": { "type": "string" },
        "having": { "type": "string" },
        "input": { "$ref": "#/$defs/fact_source" },
        "anchor": { "$ref": "#/$defs/fact_source" },
        "related_kinds": { "type": "array", "items": { "type": "string" } },
        "match_on": { "type": "string" },
        "evidence": { "type": "object" },
        "finding": { "$ref": "#/$defs/finding" }
      }
    }
  }
}