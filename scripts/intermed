#!/usr/bin/env bash
# Run the local intermed binary from the repo (no global install needed).
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="$ROOT/target/debug/intermed"
if [[ ! -x "$BIN" ]]; then
  echo "intermed: binary not found — run: cargo build --features duckdb" >&2
  exit 1
fi
exec "$BIN" "$@"